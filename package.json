{
  "name": "football-pattern-lab",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:react": "vite --host 127.0.0.1 --port 5173",
    "build:react": "vite build && node scripts/prepare-react-dist.mjs",
    "preview:react": "vite preview --host 127.0.0.1 --port 4173",
    "typecheck": "tsc --noEmit",
    "test:api-football": "tsc -p tsconfig.test.json && node scripts/test-api-football-normalizer.mjs",
    "test:journal": "tsc -p tsconfig.test.json && node scripts/test-journal.mjs",
    "test": "tsc -p tsconfig.test.json && node scripts/test-api-football-normalizer.mjs && node scripts/test-journal.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
